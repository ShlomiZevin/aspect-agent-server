package-lock.json

.env.bak
.env
.env.production*
.env.cloudsql
# Catch every other local env variant (backups, dumps) — all hold secrets
.env.*
!.env.*.template
!.env.*.example
node_modules/
*.log
.DS_Store
*-service-account*.json
data/
!data/*-schema-description.txt
# The unqualified `data/` rule above matches ANY directory named `data`
# anywhere in the repo (gitignore treats it as **/data/) — it was meant for
# the top-level schema-dump directory but was also silently swallowing
# insights/data/hypertoy.seed.js, a real source file, not runtime output.
# Only the generated-insights.json runtime cache in that directory should
# stay ignored.
!insights/data/
!insights/data/hypertoy.seed.js
insights/data/generated-insights.json
temp/
app.yaml
app.flexible.yaml

# Cloud SQL configuration
scripts/cloud-sql/cloud-sql-config.env
scripts/cloud-sql/*.env
!scripts/cloud-sql/*.env.template
